{
  "name": "claudecode-pty",
  "version": "0.3.0",
  "description": "Production-grade MCP server for interactive PTY session management in Claude Code. Spawn background processes, send input, stream and grep output, all through seven focused tools.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "claudecode-pty": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "pretest": "npm run build",
    "test": "node --test test/*.test.mjs",
    "test:unit": "node --test test/unit-*.test.mjs",
    "test:integration": "node --test test/integration-*.test.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "node-pty": "^1.1.0",
    "safe-regex2": "^4.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/node": "^22.10.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "claude-code",
    "claudecode",
    "anthropic",
    "pty",
    "pseudo-terminal",
    "terminal",
    "background-process",
    "interactive",
    "dev-server"
  ],
  "license": "MIT"
}
